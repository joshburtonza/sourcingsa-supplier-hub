# ZA Supplier Hub — environment variables schema.
#
# Local dev: copy this to `.env` and fill the values. `.env` is gitignored.
# Production: set these via `wrangler secret put <NAME>` (one-off per var)
# or via the Cloudflare dashboard → Workers → zasupplierhub → Settings →
# Variables and Secrets.

# ── Supabase (client) ────────────────────────────────────────────────
# The publishable (anon) key + URL ship to the browser. Safe in source
# but kept out of git anyway so we don't accidentally commit a non-anon
# key by mistake later.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Supabase (server, service role) ──────────────────────────────────
# Bypasses RLS. NEVER expose to the browser. Used server-side by:
#   - the Shopify orders-paid webhook (provisioning new members)
#   - any admin endpoint that creates users or grants roles
SUPABASE_SERVICE_ROLE_KEY=

# ── Shopify ──────────────────────────────────────────────────────────
# Once-off checkout URL for the "Get Instant Access" buttons. Replace
# the preview-theme URL the project shipped with.
VITE_SHOPIFY_CHECKOUT_URL=

# Webhook signing secret from Shopify Admin → Notifications → Webhooks
# → click "Create webhook" → copy the secret shown beneath the webhook
# definition. Used to verify the X-Shopify-Hmac-Sha256 header on
# /api/webhooks/shopify/orders-paid.
SHOPIFY_WEBHOOK_SECRET=
